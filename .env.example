# ============================================================================
# BetVector — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the real .env file to version control.
#
# These variables are read by the pipeline (run_pipeline.py) and the
# Streamlit dashboard (src/delivery/dashboard.py).
# ============================================================================

# --- Dashboard Access ---
# Simple password gate for the Streamlit dashboard.
# Leave empty to disable the password gate (useful for local dev).
DASHBOARD_PASSWORD=

# --- Email Alerts ---
# The Gmail address that BetVector sends emails from (and to).
FROM_EMAIL=

# Gmail App Password for the above email address.
# Generate one at: https://myaccount.google.com/apppasswords
# (Requires 2FA enabled on your Google account.)
GMAIL_APP_PASSWORD=

# --- API Keys ---
# RapidAPI key for API-Football (free tier: 100 requests/day).
# Sign up at: https://www.api-football.com/
API_FOOTBALL_KEY=
