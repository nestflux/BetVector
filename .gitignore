# ===== BetVector .gitignore =====

# --- Database files ---
# The main database IS tracked so GitHub Actions has it.
# WAL/SHM are temp files and should not be committed.
!data/betvector.db
data/*.db-wal
data/*.db-shm
data/backups/

# --- Raw scraped data (re-downloadable, don't bloat repo) ---
data/raw/

# --- Team badge images (tracked for Streamlit Cloud deployment) ---
# data/badges/

# --- Python bytecode ---
__pycache__/
*.py[cod]
*$py.class

# --- Virtual environment ---
venv/
.venv/
env/

# --- Environment variables (secrets!) ---
.env
.streamlit/secrets.toml

# --- Email config (may contain real SMTP credentials) ---
config/email_config.yaml

# --- Jupyter notebooks ---
.ipynb_checkpoints/

# --- Serialized models ---
*.pkl
*.joblib

# --- macOS ---
.DS_Store

# --- IDE / Editor ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Distribution / Build ---
dist/
build/
*.egg-info/
*.egg

# --- pytest / coverage ---
.pytest_cache/
htmlcov/
.coverage
