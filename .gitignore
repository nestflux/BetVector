# ===== BetVector .gitignore =====

# --- Database files ---
# After E33 cloud migration, the database lives in Neon PostgreSQL.
# The local SQLite file is for development only — not tracked in git.
data/betvector.db
data/*.db-wal
data/*.db-shm
data/backups/

# --- Raw scraped data (re-downloadable, don't bloat repo) ---
data/raw/

# --- Pipeline logs (generated daily by launchd, rotated at 30 days) ---
data/logs/

# --- Team badge images (tracked for Streamlit Cloud deployment) ---
# data/badges/

# --- Python bytecode ---
__pycache__/
*.py[cod]
*$py.class

# --- Virtual environment ---
venv/
.venv/
env/

# --- Environment variables (secrets!) ---
.env
.streamlit/secrets.toml

# --- Email config (may contain real SMTP credentials) ---
config/email_config.yaml

# --- Jupyter notebooks ---
.ipynb_checkpoints/

# --- Serialized models ---
*.pkl
*.joblib

# --- macOS ---
.DS_Store

# --- IDE / Editor ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Distribution / Build ---
dist/
build/
*.egg-info/
*.egg

# --- pytest / coverage ---
.pytest_cache/
htmlcov/
.coverage
