# ===== BetVector .gitignore =====

# --- Database files ---
data/*.db
data/*.db-wal
data/*.db-shm

# --- Raw scraped data (re-downloadable, don't bloat repo) ---
data/raw/

# --- Python bytecode ---
__pycache__/
*.py[cod]
*$py.class

# --- Virtual environment ---
venv/
.venv/
env/

# --- Environment variables (secrets!) ---
.env

# --- Jupyter notebooks ---
.ipynb_checkpoints/

# --- Serialized models ---
*.pkl
*.joblib

# --- macOS ---
.DS_Store

# --- IDE / Editor ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Distribution / Build ---
dist/
build/
*.egg-info/
*.egg

# --- pytest / coverage ---
.pytest_cache/
htmlcov/
.coverage
