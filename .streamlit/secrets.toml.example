# ============================================================================
# BetVector — Streamlit Cloud Secrets
# ============================================================================
# Copy this file to secrets.toml (or configure in the Streamlit Cloud
# dashboard under Settings → Secrets) with your actual values.
#
# NEVER commit the real secrets.toml to version control.
# The .gitignore already excludes .streamlit/secrets.toml.
#
# These secrets are accessible in the app via:
#   import streamlit as st
#   st.secrets["DASHBOARD_PASSWORD"]
# ============================================================================

# --- Dashboard Access ---
# Simple password gate for the Streamlit dashboard.
# Leave empty to disable the password gate (dev mode).
DASHBOARD_PASSWORD = "your-dashboard-password-here"

# --- Email Alerts ---
# Gmail App Password for sending morning/evening/weekly emails.
# Generate one at: https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD = "your-gmail-app-password-here"

# --- API Keys ---
# RapidAPI key for API-Football (free tier: 100 requests/day).
# Get one at: https://www.api-football.com/
API_FOOTBALL_KEY = "your-api-football-key-here"

# --- Database (Neon PostgreSQL — Cloud Deployment) ---
# BetVector uses Neon PostgreSQL (free tier) as the production database.
# The connection string is read by src/database/db.py via st.secrets.
# Leave commented out for local development (uses SQLite from config).
#
# Get your connection string from: https://console.neon.tech
# Format: postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
#
[database]
connection_string = "postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"
