{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dashboard",
      "runtimeExecutable": "venv/bin/streamlit",
      "runtimeArgs": ["run", "src/delivery/dashboard.py", "--server.port", "8501"],
      "port": 8501
    },
    {
      "name": "demo",
      "runtimeExecutable": "venv/bin/streamlit",
      "runtimeArgs": ["run", "demo_app.py", "--server.port", "8502"],
      "port": 8502
    },
    {
      "name": "wc_page",
      "runtimeExecutable": "venv/bin/streamlit",
      "runtimeArgs": ["run", "src/delivery/views/world_cup.py", "--server.port", "8505", "--server.headless", "true"],
      "port": 8505
    },
    {
      "name": "report",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8503", "--directory", "docs"],
      "port": 8503
    },
    {
      "name": "preview",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8504", "--directory", "/tmp"],
      "port": 8504
    },
    {
      "name": "dashboard_scan",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "DASHBOARD_PASSWORD='' exec venv/bin/streamlit run src/delivery/dashboard.py --server.port 8506 --server.headless true --server.runOnSave false"],
      "port": 8506
    }
  ]
}
